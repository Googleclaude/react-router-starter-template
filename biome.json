{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "build",
      ".react-router",
      ".wrangler",
      "node_modules",
      "package-lock.json",
      "worker-configuration.d.ts"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnreachable": "error",
        "noUnusedVariables": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "error"
      },
      "suspicious": {
        "noDebugger": "error",
        "noEmptyBlockStatements": "warn"
      }
    }
  },
  "formatter": {
    "enabled": false
  }
}
