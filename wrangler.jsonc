{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "react-router-starter-template",
  "compatibility_date": "2025-04-01",
  "main": "./workers/app.ts",
  "assets": {
    "binding": "ASSETS",
    "directory": "./build/client"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "VALUE_FROM_CLOUDFLARE": "Hello from Cloudflare"
  }
}
