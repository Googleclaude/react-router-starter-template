{
  "name": "decisoes-stf",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "react-router typegen && wrangler types && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply decisoes-db --local",
    "db:migrate": "wrangler d1 migrations apply decisoes-db --remote"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@react-router/cloudflare": "^7.6.0",
    "isbot": "^5.1.27",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250515.0",
    "@react-router/dev": "^7.6.0",
    "@tailwindcss/vite": "^4.1.5",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.7",
    "wrangler": "^4.16.0"
  }
}
